# ============================================================================
# PulseSim: Environment Configuration Template
# Copy this file to .env and fill in the values
# ============================================================================

# FastAPI Settings
PORT=8000
HOST=0.0.0.0
ENV=development

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Redis Live State Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# PostgreSQL Persistent Database (Use asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/pulsesim

# OpenAI LLM API (Required for PersonaEngine and EvaluationEngine)
OPENAI_API_KEY=your_openai_api_key_here
